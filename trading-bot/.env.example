# ============================================================
# Fable 5 Trading Bot configuration
# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required
# for paper-trading mode.
# ============================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=

# --- Safety: paper trading is the default ---
# Keep DRY_RUN=true until you have weeks of good paper results.
DRY_RUN=true
PAPER_STARTING_USD=1000

# Live trading requires BOTH of these in addition to Coinbase keys:
#   DRY_RUN=false
#   LIVE_TRADING_CONFIRMED=I understand I can lose money
LIVE_TRADING_CONFIRMED=

# --- Coinbase Advanced Trade (only needed for live mode) ---
# Create at https://www.coinbase.com/settings/api
# Grant View + Trade only. NEVER grant transfer/withdrawal permission.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- What to trade ---
PRODUCTS=BTC-USD,ETH-USD
DECISION_INTERVAL_MINUTES=15

# --- Risk limits ---
MAX_POSITION_PCT=10          # max % of portfolio equity per single trade
MAX_DAILY_LOSS_PCT=5         # halt trading for the day past this drawdown
MIN_CONFIDENCE=0.7           # ignore AI decisions below this confidence
TRADE_COOLDOWN_MINUTES=60    # min gap between trades on the same product
MIN_TRADE_USD=10             # skip dust-sized trades

# --- Model ---
ANTHROPIC_MODEL=claude-fable-5
