# Profit Funnel — configuration
# Copy to your server's environment (or `source` it) before running bin/funnel.
# Tokens are placeholders — paste your real GHL values to go live.

# --- Business profile ---
FUNNEL_BUSINESS_NAME="Gulf Coast Painting PEI"
FUNNEL_LOCATION="Prince Edward Island"
FUNNEL_SERVICES="house washing,pressure washing,exterior painting"
FUNNEL_CONTACT_EMAIL="gulfcoastpaintingpei@gmail.com"

# --- Channels & cadence ---
FUNNEL_PLATFORMS="tiktok,instagram,youtube"
FUNNEL_POSTS_PER_DAY="50"        # socials per platform/day (your chosen number)
FUNNEL_GBP_POSTS_PER_DAY="3"     # Google Business Profile before/after per day

# --- Offer (free quote, no upfront charge) ---
FUNNEL_OFFER_NAME="Free Quote — Soft Wash + Power Wash"
FUNNEL_OFFER_DESC="a light chemical wash that kills mildew and lifts dirt, then a power wash and rinse"
FUNNEL_SIZE_NOTE="depending on the size of your home"
FUNNEL_FROM_PRICE_CENTS="69900"  # $699 minimum
FUNNEL_CURRENCY="cad"
FUNNEL_BOOKING_URL="mailto:gulfcoastpaintingpei@gmail.com?subject=Free%20Quote%20-%20House%20Wash%20%26%20Power%20Wash"
FUNNEL_CHARGE_UPFRONT="false"    # never charge before the work is done

# --- GHL posting (fill in your GoHighLevel webhook + token) ---
FUNNEL_TIKTOK_ENDPOINT=""
FUNNEL_TIKTOK_TOKEN=""
FUNNEL_INSTAGRAM_ENDPOINT=""
FUNNEL_INSTAGRAM_TOKEN=""
FUNNEL_YOUTUBE_ENDPOINT=""
FUNNEL_YOUTUBE_TOKEN=""
FUNNEL_GBP_ENDPOINT=""
FUNNEL_GBP_TOKEN=""

# --- Optional: Stripe deposit (off by default) ---
# STRIPE_SECRET="sk_test_..."
# FUNNEL_SUCCESS_URL="https://yoursite.com/thanks"
# FUNNEL_CANCEL_URL="https://yoursite.com/"

# --- Optional: nicer frame text ---
# FUNNEL_FONT="/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
